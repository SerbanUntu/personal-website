---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
---

<Layout title="Șerban Untu" description="Welcome to my website">
	<main
		class="w-full max-w-3xl mx-auto flex flex-col gap-4 text-lg p-8 relative"
	>
		<h1 class="text-4xl font-semibold">Șerban Untu</h1>
		<p class="text-xl">Software engineer.</p>
		<Image
			src="/pfp.png"
			alt=""
			loading="eager"
			width={64}
			height={64}
			class="hidden sm:block w-16 h-16 rounded-full absolute top-8 right-8"
		/>
		<div class="flex items-center gap-2">
			<Icon name="map-pin" />
			<p>Delft, Netherlands</p>
		</div>
		<p class="us:text-justify">
			Hello! I'm Șerban, a software engineer and student at the
			<a
				href="https://www.tudelft.nl/en/onderwijs/opleidingen/bachelors/computer-science-and-engineering/bachelor-of-computer-science-and-engineering"
				target="_blank"
				class="text-primary underline"
				><Image
					src="/tudelft.svg"
					alt=""
					loading="eager"
					width={16}
					height={16}
					class="w-4 h-4 inline-block relative -top-px mr-1"
				/>Delft University of Tech- nology</a
			>. I've worked as an intern at
			<a
				href="https://www.jetbrains.com/teamcity/"
				target="_blank"
				class="text-primary underline"
				><Image
					src="/teamcity.png"
					alt=""
					loading="eager"
					width={16}
					height={16}
					class="w-4 h-4 inline-block relative -top-px mr-1"
				/>JetBrains</a
			>, implementing integrations for TeamCity, the company's all-in-one
			CI/CD solution. I've also worked at
			<a
				href="https://return.energy/"
				target="_blank"
				class="text-primary underline"
				><Image
					src="/returnenergy.jpg"
					alt=""
					loading="eager"
					width={16}
					height={16}
					class="w-4 h-4 inline-block relative -top-px mr-1"
				/>Return Energy</a
			> as part of the quantitative finance team, building the execution engine
			for their bespoke trading platform.
		</p>
		<p class="us:text-justify">
			I've also worked on
			<a
				href="https://www.projectclub.dev"
				target="_blank"
				class="text-primary underline"
				><Image
					src="/projectclub.svg"
					alt=""
					loading="eager"
					width={16}
					height={16}
					class="w-4 h-4 inline-block relative -top-px mr-1"
				/>Project Club</a
			>, a platform for learning advanced programming concepts by building
			projects, and I've been Head of Development at
			<a
				href="https://www.aerovia.org"
				target="_blank"
				rel="noopener noreferrer"
				class="text-primary underline"
			>
				<Image
					src="/aerovia.svg"
					alt=""
					loading="eager"
					width={16}
					height={16}
					class="w-4 h-4 inline-block relative -top-px mr-1"
				/>AeroVia</a
			>, a non-profit organization and community that makes aerospace
			engineering accessible to everyone.
		</p>
		<nav class="flex flex-col items-center gap-4 mt-8">
			<a
				href="/projects"
				class="bg-primary text-background hover:opacity-80 border rounded-lg transition-opacity py-4 w-full h-full block text-center max-w-sm"
				>View my projects</a
			>
			<a
				href="/contact"
				class="hover:bg-muted/20 border rounded-lg transition-colors py-4 w-full h-full block text-center max-w-sm"
				>Contact me</a
			>
		</nav>
	</main>
</Layout>
